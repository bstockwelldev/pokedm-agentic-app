# Copy this file to `.env` and replace the placeholder values with your keys.
# ─────────────────────────────────────────────────────────────────────────────

# ── Models ────────────────────────────────────────────────────────────────────

# Default model for the DM agent (smart tier).
# Groq: groq/llama-3.3-70b-versatile | Google: gemini-2.5-flash | OpenAI: openai/gpt-4o
LLM_MODEL=gemini-2.5-flash

# Per-tier model overrides (optional — falls back to LLM_MODEL)
# SMART_MODEL=groq/llama-3.3-70b-versatile
# FAST_MODEL=groq/llama-3.1-8b-instant
# VISION_MODEL=google/gemini-2.0-flash

# Per-agent model overrides (optional — takes precedence over tier defaults)
# DM_MODEL=groq/llama-3.3-70b-versatile
# ROUTER_MODEL=groq/llama-3.1-8b-instant
# LORE_MODEL=groq/llama-3.3-70b-versatile
# RULES_MODEL=groq/llama-3.3-70b-versatile
# DESIGN_MODEL=groq/llama-3.3-70b-versatile
# STATE_MODEL=groq/llama-3.1-8b-instant

# ── API Keys ──────────────────────────────────────────────────────────────────

# Google Gemini — https://aistudio.google.com/app/apikey
GOOGLE_GENERATIVE_AI_API_KEY=your-gemini-api-key-here
GEMINI_API_KEY=your-gemini-api-key-here

# Groq — https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key-here

# OpenAI — required for DALL-E 3 image generation
# https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# ── Server ────────────────────────────────────────────────────────────────────

PORT=3001
NODE_ENV=development

# ── Storage ───────────────────────────────────────────────────────────────────

# 'file'     — JSON files in SESSIONS_DIR (local dev only; ephemeral on Vercel)
# 'postgres' — PostgreSQL (required for production/Vercel persistence)
# Auto-detected: NODE_ENV=production or VERCEL=1 → postgres; otherwise → file
STORAGE_PROVIDER=file

# File adapter: where session JSON files are written
SESSIONS_DIR=./sessions

# PostgreSQL adapter — required when STORAGE_PROVIDER=postgres
#
# Supabase (recommended for Vercel deployments):
#   1. Create a free project at https://supabase.com
#   2. Go to Project Settings → Database → Connection Pooling
#   3. Enable Supabase Pooler (Transaction mode, port 6543)
#   4. Copy the connection string and paste it here
#
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
#
# Local PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/pokedm

# Set to 'true' if your database requires SSL (always true for Supabase prod)
# DATABASE_SSL=true

# ── Security ──────────────────────────────────────────────────────────────────

# CORS: comma-separated list of allowed browser origins.
# Default includes localhost:3000 and :5173 for local dev.
# Production: set to your deployed Vercel URL.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Rate limiting (requests per IP per minute across all /api routes)
RATE_LIMIT_MAX=60

# ── Image Generation ──────────────────────────────────────────────────────────

# Max DALL-E 3 images generated per session (cost control)
IMAGE_LIMIT_PER_SESSION=5

# ── Voice ─────────────────────────────────────────────────────────────────────

# TTS provider: 'browser' (Web Speech API, free) or 'openai' (higher quality)
TTS_PROVIDER=browser

# ── Streaming ─────────────────────────────────────────────────────────────────

# Enable streamText for DM narration (POST /api/v1/agent/stream)
# Set to 'true' to default the client to the streaming endpoint
STREAMING_ENABLED=true
